<resources>
    <string name="app_name">DIGI Keyboard by kostyamat</string>
    <string name="accessibility_service_description">Перехоплює натискання клавіш фізичної клавіатури та емулює правильні символи для кількох розкладок за допомогою віртуального IME.</string>
    <string name="accessibility_service_label">DIGI Key Interceptor</string>

    <string name="status_loading">Статус: Завантаження…</string>
    <string name="status_active">Статус: АКТИВНИЙ</string>
    <string name="status_inactive">Статус: НЕАКТИВНИЙ</string>
    <string name="adb_commands_title">Команди ADB (натисніть, щоб скопіювати):</string>

    <string name="setup_wizard_title">Майстер налаштування</string>
    <string name="step_enable_ime">1. Увімкнути клавіатуру</string>
    <string name="step_set_default">2. Встановити за замовчуванням</string>
    <string name="step_enable_accessibility">3. Увімкнути службу доступності</string>
    <string name="keyboard_setup_instruction">Активуйте клавіатуру в налаштуваннях та встановіть її за замовчуванням:</string>

    <string name="languages_title">Увімкнені розкладки (Ctrl+Space для перемикання):</string>
    <string name="lang_en">Англійська</string>
    <string name="lang_es">Іспанська</string>
    <string name="lang_ua">Українська</string>
    <string name="lang_ru">Російська</string>
    <string name="lang_ro">Румунська</string>

    <string name="command_copied">Команду скопійовано в буфер обміну!</string>
    <string name="import_custom_layout">Імпортувати власну розкладку JSON</string>
    <string name="import_success">Імпортовано: %s</string>
    <string name="import_failed">Помилка імпорту: %s</string>
    <string name="ime_off">IME ВИМКНЕНО</string>
    <string name="no_focus">НЕМАЄ ФОКУСУ</string>
    <string name="ime_disabled">IME ВИМКНЕНО</string>

    <string name="adb_grant_secure_desc">1. Надати дозвіл WRITE_SECURE_SETTINGS (через ADB):</string>
    <string name="adb_grant_secure">adb shell pm grant com.kostyamat.r2r_q android.permission.WRITE_SECURE_SETTINGS</string>

    <string name="adb_restricted_settings_desc">2. Дозволити обмежені налаштування (для Android 13+):</string>
    <string name="adb_restricted_settings">adb shell appops set com.kostyamat.r2r_q ACCESS_RESTRICTED_SETTINGS allow</string>

    <string name="adb_enable_service_desc">3. Увімкнути службу доступності через ADB:</string>
    <string name="adb_enable_service">adb shell settings put secure enabled_accessibility_services com.kostyamat.r2r_q/com.kostyamat.r2r_q.KeyInterceptorService</string>

    <string name="adb_activate_acc_desc">4. Активувати доступність через ADB:</string>
    <string name="adb_activate_acc">adb shell settings put secure accessibility_enabled 1</string>

    <string name="adb_allow_overlay_desc">5. Дозволити відображення поверх інших вікон:</string>
    <string name="adb_allow_overlay">adb shell appops set com.kostyamat.r2r_q SYSTEM_ALERT_WINDOW allow</string>
</resources>

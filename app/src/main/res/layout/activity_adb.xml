<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Статус -->
        <TextView
            android:id="@+id/statusTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_loading"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp" />

        <!-- Контейнер налаштування (Wizard + ADB) -->
        <LinearLayout
            android:id="@+id/setupContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <!-- Автоматичне налаштування (Local ADB) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/adb_auto_setup_title"
                android:textColor="#FFD600"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/adb_auto_setup_desc"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnDevOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_step_1_dev_options"
                android:background="@drawable/btn_bg_selector"
                android:textColor="@color/btn_text_selector"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnAutoGrant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_step_2_auto_grant"
                android:background="@drawable/adb_btn_selector"
                android:textColor="#FFD600"
                android:layout_marginBottom="16dp" />
        </LinearLayout>

        <!-- Розумне перемикання -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/smart_switcher_title"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/smart_switcher_desc"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <Spinner
            android:id="@+id/spinnerFallbackIme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_bg_selector"
            android:padding="12dp"
            android:layout_marginBottom="24dp" />

        <!-- Дія клавіші DIGI Online (відображається лише на DIGI боксах) -->
        <LinearLayout
            android:id="@+id/digiWorkaroundContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/q_action_title"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/q_action_desc"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinnerQAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_bg_selector"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />
        </LinearLayout>

        <!-- Кастомні кнопки пульта -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/custom_remaps_title"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/custom_remaps_desc"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:id="@+id/remapsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="8dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnCatchKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_add_remap"
            android:background="@drawable/btn_bg_selector"
            android:textColor="@color/btn_text_selector"
            android:layout_marginBottom="24dp" />

        <!-- Мови (завжди залишаються) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/languages_title"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/languagesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="8dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnImportLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/import_custom_layout"
            android:background="@drawable/btn_bg_selector"
            android:textColor="@color/btn_text_selector"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_gravity="end"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
